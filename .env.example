# ========== DISCORD (bắt buộc) ==========
# User token của bạn (lấy từ DevTools -> Network -> Header Authorization)
DISCORD_USER_TOKEN=your_discord_user_token

# ========== SETTINGS (tuỳ chỉnh) ==========
# Tần suất cập nhật lyrics (giây). Khuyến nghị: 2-3s
POLL_INTERVAL=2

# Format khi không tìm thấy lyrics. Biến: {artist} {title} {album} {url}
STATUS_FORMAT=🎵 {artist} - {title}
